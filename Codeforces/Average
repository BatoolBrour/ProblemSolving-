#include <iostream>
#include <iomanip>
using namespace std;

double mean_calculator(int size, double array[]) {
    double sum = 0;
    for(int i = 0; i < size; i++) {
        sum += array[i];
    }
    return sum / size;
}

int main() {
    int n;
    cin >> n;

    double array[n];

    for(int i = 0; i < n; i++) {
        cin >> array[i];
    }

    cout << fixed << setprecision(7) << mean_calculator(n, array);

    return 0;
}
