#include <iostream>
using namespace std ;

bool prime (int num ){
    if(num<2)
    return false;
  else  for(int test=2;test*test<=num;test++){
        if(num%test==0)
        return false ;
    }
    return true ;
}

int main()
{ 
   int t ; cin>>t; int number; 
   while (t--){
       cin>>number;
      bool isPrime= prime (number);
      if(isPrime) cout<<"YES\n"; else cout<<"NO\n";
   }
   
    return 0;
}
